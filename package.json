{
  "name": "@omlabs/lumen",
  "version": "0.1.0",
  "description": "Vision-first Computer Use Agent engine.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:setup": "bash evals/benchmark/setup.sh",
    "benchmark": "tsx --env-file .env evals/benchmark/loop.ts",
    "benchmark:lumen": "tsx --env-file .env evals/benchmark/loop.ts --lumen-only",
    "benchmark:stagehand": "FRAMEWORKS=stagehand tsx --env-file .env evals/benchmark/loop.ts",
    "benchmark:browser-use": "FRAMEWORKS=browser-use tsx --env-file .env evals/benchmark/loop.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.3.0",
    "chrome-launcher": "^1.1.2",
    "openai": "^4.96.0",
    "sharp": "^0.33.5",
    "tslib": "^2.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "ai",
    "browser",
    "automation",
    "computer-use",
    "cua",
    "vision"
  ],
  "author": "omlabs",
  "license": "MIT"
}
